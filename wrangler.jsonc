{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trinitrotorol-github-io",
  "compatibility_date": "2026-06-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "routes": [
    {
      "pattern": "trinitrotorol.com",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
